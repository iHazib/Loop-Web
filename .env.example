# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ════════════════════════════════════════════════
#  Admin authentication — copy this file to `.env`
#  (both Vite and the Express server read `.env`).
# ════════════════════════════════════════════════

# Google OAuth Client ID (type: Web application) from Google Cloud Console.
# Add your site URL (e.g. http://localhost:3000) under "Authorised JavaScript origins".
# The Client ID is NOT a secret (it ships in client JS). Use the SAME value for both:
#   VITE_ one renders the Google button (client); the plain one verifies tokens (server).
VITE_GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_ID=""

# REQUIRED — comma-separated emails allowed into /admin. Enforced server-side.
# (Server reads ADMIN_EMAILS only — never a VITE_ var.)
ADMIN_EMAILS="you@example.com"

# REQUIRED — second-factor admin passcode. Server-only secret.
# Do NOT prefix with VITE_ (that would leak it into the public client bundle).
ADMIN_PASSCODE=""

# REQUIRED IN PRODUCTION — long random string used to sign admin session cookies.
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=""

# Port the API server listens on (default 8787).
PORT="8787"

# ── Supabase (database) ──
# Project URL and the SERVICE ROLE key (Settings → API).
# The service_role key bypasses RLS and is SERVER-ONLY — never prefix with VITE_,
# never expose it to the browser, and never commit it.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
